{
  "productName": "Segatt Tools",
  "version": "1.7.5",
  "identifier": "com.segatt.tools",
  "build": {
    "beforeDevCommand": "npm run dev",
    "devUrl": "http://localhost:3000",
    "beforeBuildCommand": "npm run build",
    "frontendDist": "../out"
  },
  "app": {
    "windows": [
      {
        "title": "Segatt Tools v1.7.5 — RE-ELITE System",
